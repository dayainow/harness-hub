# HarnessHub backend env example.

# Prisma + Supabase Postgres.
#   DATABASE_URL → pgbouncer pooled connection (used at runtime).
#   DIRECT_URL   → direct Postgres connection (used by `prisma migrate`).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# HTTP port (Render/Railway/Vercel inject their own; default for local dev).
PORT=3002

# Required by AdminGuard. Requests to admin endpoints
# (POST /harnesses, POST /harnesses/:org/:name/benchmarks,
#  GET /users, PATCH /users/:id/role) must send `X-Admin-Secret: <this value>`.
ADMIN_SECRET=replace-with-a-long-random-string

# Supabase JWT verification.
#   The Supabase JWKS endpoint is used to verify modern ECDSA-signed
#   access tokens (kid + ES256/RS256). If a token cannot be verified via
#   JWKS, SUPABASE_JWT_SECRET is used as the legacy HMAC fallback.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# GitHub API token — README/메타데이터 크롤링 및 AI 가이드 생성 시 사용.
# 미설정 시 비인증 요청(시간당 60회)으로 제한됨.
GITHUB_TOKEN=

GROQ_API_KEY=            # Groq API 키 — AI 가이드 생성용 (무료: console.groq.com)
